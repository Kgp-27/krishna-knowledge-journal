---
interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<section class="section">

  <div class="container">

    <header class="section-header">

      <h2>{title}</h2>

      {description && (
        <p>{description}</p>
      )}

    </header>

    <slot />

  </div>

</section>