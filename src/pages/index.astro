---
import { getLatestArticles } from "../lib/articles";

import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import Hero from "../components/Hero.astro";
import Section from "../components/Section.astro";
import PillarCard from "../components/PillarCard.astro";
const latestArticles = await getLatestArticles();
---

<BaseLayout
  title="Krishna's Knowledge Journal"
  description="Finance, Economics, Indian Banking, Taxation and History explained from first principles."
>

  <Hero />

  <Section
    title="Explore the Library"
    description="Explore the five permanent disciplines that form the foundation of Krishna's Knowledge Journal."
  >

    <div class="pillar-grid">

      <PillarCard
        title="Finance"
        description="Money, investing, corporate finance and financial markets."
      />

      <PillarCard
        title="Economics"
        description="Microeconomics, macroeconomics and economic thought."
      />

      <PillarCard
        title="Indian Banking"
        description="The Reserve Bank of India, commercial banking, regulation and monetary systems."
      />

      <PillarCard
        title="Taxation"
        description="Direct taxation, indirect taxation and public finance."
      />

      <PillarCard
        title="History"
        description="Economic history, financial history and institutional development."
      />

    </div>

  </Section>

  <Section
    title="Latest Articles"
    description="The latest publications from Krishna's Knowledge Journal."
  >

    {
      latestArticles.length > 0 ? (

        <div class="pillar-grid">
        {latestArticles.map((article) => (

  <ArticleCard
    article={article}
  />

))}

        </div>

      ) : (

        <p>No articles have been published yet.</p>

      )
    }

  </Section>

</BaseLayout>