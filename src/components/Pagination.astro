---
interface Props {
  currentPage: number;
  totalPages: number;
  baseUrl: string;
}

const {
  currentPage,
  totalPages,
  baseUrl,
} = Astro.props;

function pageUrl(page: number) {
  return page === 1
    ? baseUrl
    : `${baseUrl}/page/${page}`;
}
---

{
  totalPages > 1 && (

    <nav
      class="pagination"
      aria-label="Pagination"
    >

      {
        currentPage > 1 && (

          <a href={pageUrl(currentPage - 1)}>
            ← Previous
          </a>

        )
      }

      {

        Array.from(
          { length: totalPages },
          (_, i) => i + 1
        ).map((page) => (

          <a
            href={pageUrl(page)}
            class={
              page === currentPage
                ? "active"
                : ""
            }
          >

            {page}

          </a>

        ))

      }

      {
        currentPage < totalPages && (

          <a href={pageUrl(currentPage + 1)}>
            Next →
          </a>

        )
      }

    </nav>

  )
}